{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "pretty": true,
    "paths": {
      "@heroku/ai": ["./src/lib/ai/types.d.ts"]
    },
    "rootDirs": ["./src"],
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["./src/**/*"],
  "exclude": ["./src/commands/ai/models/**/*"],
  "ts-node": { "esm": true }
}
